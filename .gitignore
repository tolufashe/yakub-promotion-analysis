# =============================================================================
# YAKUB PROMOTION ANALYSIS - GITIGNORE
# =============================================================================

# -----------------------------------------------------------------------------
# DATA FILES
# -----------------------------------------------------------------------------
# Don't commit raw data files (too large, should be downloaded separately)
data/raw/*.csv
data/raw/*.xlsx
data/raw/*.xls
data/raw/*.json

# Don't commit processed data (can be regenerated)
data/processed/*.csv
data/processed/*.pkl
data/processed/*.parquet

# -----------------------------------------------------------------------------
# JUPYTER NOTEBOOK
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
*.ipynb_checkpoints

# Jupyter runtime
.jupyter/

# -----------------------------------------------------------------------------
# PYTHON
# -----------------------------------------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

